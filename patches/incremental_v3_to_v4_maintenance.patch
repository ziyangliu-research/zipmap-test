+def run_packet_maintenance(
+    gaussians: GaussianModel,
+    opt,
+    scene: Scene,
+    args,
+    radii: torch.Tensor,
+    packet_id: int,
+    train_step: int,
+    local_iteration: int,
+    global_iteration: int,
+) -> Dict[str, Any]:
+    """Run one standard GraphDECO densification/pruning event.
+
+    The caller must invoke this after optimizer.step() for the selected local
+    iteration. Densification statistics are accumulated before that step.
+    """
+    if args.packet_maintenance_mode != "standard":
+        raise ValueError(f"Unsupported packet maintenance mode: {args.packet_maintenance_mode}")
+
+    count_before = int(gaussians.get_xyz.shape[0])
+    grad_threshold = (
+        float(args.packet_maintenance_grad_threshold)
+        if args.packet_maintenance_grad_threshold > 0
+        else float(opt.densify_grad_threshold)
+    )
+    max_screen_size = (
+        float(args.packet_maintenance_max_screen_size)
+        if args.packet_maintenance_max_screen_size > 0
+        else None
+    )
+
+    t0 = time.time()
+    gaussians.densify_and_prune(
+        grad_threshold,
+        float(args.packet_maintenance_min_opacity),
+        scene.cameras_extent,
+        max_screen_size,
+        radii,
+    )
+    maintenance_sec = time.time() - t0
+    count_after = int(gaussians.get_xyz.shape[0])
+
+    return {
+        "event": "standard_densify_and_prune",
+        "packet_id": int(packet_id),
+        "train_step": int(train_step),
+        "local_iteration": int(local_iteration),
+        "global_iteration": int(global_iteration),
+        "count_before": count_before,
+        "count_after": count_after,
+        "net_change": count_after - count_before,
+        "grad_threshold": grad_threshold,
+        "min_opacity": float(args.packet_maintenance_min_opacity),
+        "max_screen_size": max_screen_size,
+        "world_scale_pruning_enabled": bool(max_screen_size is not None),
+        "maintenance_sec": maintenance_sec,
+        "statistics_source": f"active-local-map renders from local iterations 1-{local_iteration}",
+        "execution_order": "optimizer_step_then_densify_and_prune",
+    }
 
 
